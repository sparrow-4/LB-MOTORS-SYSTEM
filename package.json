{
  "name": "lb-motors",
  "version": "0.0.0",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:electron": "concurrently -k \"ng serve\" \"wait-on http://localhost:4200 && electron .\"",
    "build": "ng build",
    "build:electron": "npm run build && electron-builder",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "build": {
    "appId": "com.lbmotors.dms",
    "productName": "LB Motors DMS",
    "directories": {
      "output": "release/"
    },
    "files": [
      "dist/lb-motors/browser/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "private": true,
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.9",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@tailwindcss/postcss": "^4.2.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "postcss": "^8.5.13",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.5"
  }
}
